---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { getSupabase } from '../../../lib/supabase';

const sb = getSupabase();
const { data: customers } = await sb.from('customers').select('id, name').order('name');

if (Astro.request.method === 'POST') {
  const data = await Astro.request.formData();
  await sb.from('projects').insert({
    name: data.get('name'),
    customer_id: data.get('customer_id') || null,
    description: data.get('description') || null,
    status: data.get('status'),
  });
  return Astro.redirect('/admin/prosjekter');
}
---

<AdminLayout title="Nytt prosjekt">
  <div class="max-w-xl">
    <h1 class="text-2xl font-bold mb-8">Nytt prosjekt</h1>
    <form method="POST" class="bg-gray-900 border border-gray-800 rounded-2xl p-8 space-y-5">
      <div>
        <label class="block text-sm font-medium text-gray-300 mb-1.5">Prosjektnavn *</label>
        <input name="name" required class="w-full bg-gray-800 border border-gray-700 rounded-lg px-4 py-2.5 text-white focus:outline-none focus:border-cyan-500" />
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-300 mb-1.5">Kunde</label>
        <select name="customer_id" class="w-full bg-gray-800 border border-gray-700 rounded-lg px-4 py-2.5 text-white focus:outline-none focus:border-cyan-500">
          <option value="">— Velg kunde —</option>
          {customers?.map((c: any) => <option value={c.id}>{c.name}</option>)}
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-300 mb-1.5">Beskrivelse</label>
        <textarea name="description" rows="3" class="w-full bg-gray-800 border border-gray-700 rounded-lg px-4 py-2.5 text-white focus:outline-none focus:border-cyan-500 resize-none"></textarea>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-300 mb-1.5">Status</label>
        <select name="status" class="w-full bg-gray-800 border border-gray-700 rounded-lg px-4 py-2.5 text-white focus:outline-none focus:border-cyan-500">
          <option value="aktiv">Aktiv</option>
          <option value="pause">Pause</option>
          <option value="fullfort">Fullført</option>
        </select>
      </div>
      <div class="flex gap-3 pt-2">
        <button type="submit" class="bg-cyan-500 hover:bg-cyan-400 text-gray-950 font-bold px-6 py-2.5 rounded-xl transition-colors">Lagre prosjekt</button>
        <a href="/admin/prosjekter" class="text-gray-400 hover:text-white px-6 py-2.5 transition-colors">Avbryt</a>
      </div>
    </form>
  </div>
</AdminLayout>
