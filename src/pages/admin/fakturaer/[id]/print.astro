---
import { getSupabase } from '../../../../lib/supabase';

const { id } = Astro.params;
const sb = getSupabase();

const { data: inv } = await sb
  .from('invoices')
  .select('*, customers(*), invoice_lines(*)')
  .eq('id', id)
  .single();

if (!inv) return Astro.redirect('/admin/fakturaer');

const total = (inv.invoice_lines ?? []).reduce((s: number, l: any) => s + l.unit_price * l.quantity, 0);
const mva = total * 0.25;
---

<!doctype html>
<html lang="no">
<head>
  <meta charset="UTF-8" />
  <title>Faktura {inv.invoice_number}</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; color: #1d1d1f; padding: 60px; max-width: 800px; margin: 0 auto; }
    .header { display: flex; justify-content: space-between; margin-bottom: 48px; }
    .logo { font-size: 1.5rem; font-weight: 700; }
    .logo span { color: #0891b2; }
    .meta { text-align: right; color: #6b7280; font-size: 0.9rem; }
    .meta h2 { color: #1d1d1f; font-size: 1.2rem; margin-bottom: 4px; }
    .bill-to { margin-bottom: 40px; }
    .label { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.08em; color: #9ca3af; margin-bottom: 6px; }
    .bill-to p { font-size: 0.9rem; line-height: 1.6; color: #4b5563; }
    .bill-to strong { color: #1d1d1f; font-size: 1rem; }
    table { width: 100%; border-collapse: collapse; margin-bottom: 32px; font-size: 0.9rem; }
    th { text-align: left; padding: 8px 0; border-bottom: 2px solid #e5e7eb; color: #6b7280; font-weight: 500; }
    th:last-child, td:last-child { text-align: right; }
    th:nth-child(2), td:nth-child(2), th:nth-child(3), td:nth-child(3) { text-align: right; }
    td { padding: 12px 0; border-bottom: 1px solid #f3f4f6; }
    .totals { text-align: right; font-size: 0.9rem; }
    .totals div { display: flex; justify-content: flex-end; gap: 48px; padding: 4px 0; }
    .totals .label-r { color: #6b7280; }
    .totals .grand { font-weight: 700; font-size: 1.1rem; border-top: 2px solid #e5e7eb; padding-top: 12px; margin-top: 8px; color: #0891b2; }
    .footer { margin-top: 60px; padding-top: 20px; border-top: 1px solid #e5e7eb; font-size: 0.8rem; color: #9ca3af; text-align: center; }
    @media print {
      body { padding: 0; }
      .no-print { display: none; }
    }
  </style>
</head>
<body>

  <div class="no-print" style="background:#f3f4f6;padding:12px 24px;margin:-60px -60px 40px;display:flex;justify-content:flex-end;">
    <button onclick="window.print()" style="background:#0891b2;color:#fff;border:none;padding:8px 20px;border-radius:8px;font-weight:600;cursor:pointer;">
      Skriv ut / Lagre som PDF
    </button>
  </div>

  <div class="header">
    <div>
      <div class="logo">MHH<span>Digital</span></div>
      <p style="color:#6b7280;font-size:0.85rem;margin-top:4px;">kjetil@mhhdigital.no</p>
      <p style="color:#6b7280;font-size:0.85rem;">www.mhhdigital.no</p>
    </div>
    <div class="meta">
      <h2>FAKTURA</h2>
      <p>{inv.invoice_number}</p>
      {inv.due_date && <p>Forfall: {new Date(inv.due_date).toLocaleDateString('nb-NO')}</p>}
      <p>Dato: {new Date(inv.created_at).toLocaleDateString('nb-NO')}</p>
    </div>
  </div>

  <div class="bill-to">
    <p class="label">Faktureres til</p>
    <strong>{inv.customers?.name}</strong>
    {inv.customers?.email && <p>{inv.customers.email}</p>}
    {inv.customers?.address && <p style="white-space:pre-line">{inv.customers.address}</p>}
    {inv.customers?.org_number && <p>Org.nr: {inv.customers.org_number}</p>}
  </div>

  <table>
    <thead>
      <tr>
        <th>Beskrivelse</th>
        <th>Ant.</th>
        <th>Pris</th>
        <th>Sum</th>
      </tr>
    </thead>
    <tbody>
      {inv.invoice_lines.map((l: any) => (
        <tr>
          <td>{l.description}</td>
          <td>{l.quantity}</td>
          <td>{l.unit_price.toLocaleString('nb-NO')} kr</td>
          <td>{(l.unit_price * l.quantity).toLocaleString('nb-NO')} kr</td>
        </tr>
      ))}
    </tbody>
  </table>

  <div class="totals">
    <div><span class="label-r">Netto</span><span>{total.toLocaleString('nb-NO')} kr</span></div>
    <div><span class="label-r">MVA (25%)</span><span>{mva.toLocaleString('nb-NO')} kr</span></div>
    <div class="grand"><span>Totalt å betale</span><span>{(total + mva).toLocaleString('nb-NO')} kr</span></div>
  </div>

  <div class="footer">MHH Digital · kjetil@mhhdigital.no · www.mhhdigital.no</div>

</body>
</html>
