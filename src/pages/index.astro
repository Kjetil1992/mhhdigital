---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Hjem" description="MHH Digital lager profesjonelle nettsider og apper for norske bedrifter.">

  <!-- Hero -->
  <section class="pt-40 pb-24 px-6 text-center">
    <div class="max-w-3xl mx-auto">
      <span class="inline-block text-cyan-400 text-sm font-semibold tracking-widest uppercase mb-4">Nettsider & Apper</span>
      <h1 class="text-5xl md:text-6xl font-extrabold leading-tight mb-6">
        Vi bygger digitale løsninger<br class="hidden md:block" />
        <span class="text-cyan-400">som leverer resultater</span>
      </h1>
      <p class="text-xl text-gray-400 mb-10 max-w-2xl mx-auto">
        MHH Digital hjelper bedrifter med å etablere en sterk digital tilstedeværelse – fra
        lynraske nettsider til skreddersydde mobilapper.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/kontakt" class="bg-cyan-500 hover:bg-cyan-400 text-gray-950 font-bold px-8 py-4 rounded-xl text-lg transition-colors">
          Start prosjektet ditt
        </a>
        <a href="/tjenester" class="border border-gray-700 hover:border-cyan-400 text-gray-300 hover:text-cyan-400 font-semibold px-8 py-4 rounded-xl text-lg transition-colors">
          Se tjenester
        </a>
      </div>
    </div>
  </section>

  <!-- Services overview -->
  <section class="py-20 px-6 bg-gray-900/50">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-3xl font-bold text-center mb-12">Hva vi tilbyr</h2>
      <div class="grid md:grid-cols-3 gap-8">
        <div class="bg-gray-900 border border-gray-800 rounded-2xl p-8 hover:border-cyan-900 transition-colors">
          <div class="text-4xl mb-4">🌐</div>
          <h3 class="text-xl font-bold mb-2">Nettsider</h3>
          <p class="text-gray-400">Raske, moderne og SEO-optimaliserte nettsider som konverterer besøkende til kunder.</p>
        </div>
        <div class="bg-gray-900 border border-gray-800 rounded-2xl p-8 hover:border-cyan-900 transition-colors">
          <div class="text-4xl mb-4">📱</div>
          <h3 class="text-xl font-bold mb-2">Mobilapper</h3>
          <p class="text-gray-400">Native og cross-platform apper for iOS og Android – fra idé til App Store.</p>
        </div>
        <div class="bg-gray-900 border border-gray-800 rounded-2xl p-8 hover:border-cyan-900 transition-colors">
          <div class="text-4xl mb-4">⚙️</div>
          <h3 class="text-xl font-bold mb-2">Vedlikehold & Drift</h3>
          <p class="text-gray-400">Vi sørger for at løsningene dine alltid er oppdaterte, sikre og raske.</p>
        </div>
      </div>
      <div class="text-center mt-10">
        <a href="/tjenester" class="text-cyan-400 hover:text-cyan-300 font-semibold transition-colors">
          Se alle tjenester →
        </a>
      </div>
    </div>
  </section>

  <!-- Why us -->
  <section class="py-20 px-6">
    <div class="max-w-5xl mx-auto text-center">
      <h2 class="text-3xl font-bold mb-4">Hvorfor velge MHH Digital?</h2>
      <p class="text-gray-400 mb-12 max-w-xl mx-auto">Vi er en dedikert partner – ikke bare en leverandør.</p>
      <div class="grid sm:grid-cols-2 md:grid-cols-4 gap-6 text-center">
        <div class="bg-gray-900 border border-gray-800 rounded-2xl p-6">
          <div class="text-3xl font-extrabold text-cyan-400 mb-1">100%</div>
          <div class="text-sm text-gray-400">Norsk support</div>
        </div>
        <div class="bg-gray-900 border border-gray-800 rounded-2xl p-6">
          <div class="text-3xl font-extrabold text-cyan-400 mb-1">Fast</div>
          <div class="text-sm text-gray-400">Pris, ingen overraskelser</div>
        </div>
        <div class="bg-gray-900 border border-gray-800 rounded-2xl p-6">
          <div class="text-3xl font-extrabold text-cyan-400 mb-1">Rask</div>
          <div class="text-sm text-gray-400">Leveringstid</div>
        </div>
        <div class="bg-gray-900 border border-gray-800 rounded-2xl p-6">
          <div class="text-3xl font-extrabold text-cyan-400 mb-1">5★</div>
          <div class="text-sm text-gray-400">Kundetilfredshet</div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 px-6">
    <div class="max-w-3xl mx-auto text-center bg-gradient-to-br from-cyan-950 to-gray-900 border border-cyan-900 rounded-3xl p-12">
      <h2 class="text-3xl font-bold mb-4">Klar til å ta steget?</h2>
      <p class="text-gray-400 mb-8">Ta kontakt for en gratis prat om hva vi kan bygge for deg.</p>
      <a href="/kontakt" class="bg-cyan-500 hover:bg-cyan-400 text-gray-950 font-bold px-8 py-4 rounded-xl text-lg transition-colors">
        Kom i gang
      </a>
    </div>
  </section>

</Layout>
