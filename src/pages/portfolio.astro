---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Portfolio" description="Se eksempler på nettsider og apper vi har laget.">

  <section class="pt-36 pb-16 px-6 text-center">
    <div class="max-w-2xl mx-auto">
      <span class="text-cyan-400 text-sm font-semibold tracking-widest uppercase">Arbeidet vårt</span>
      <h1 class="text-4xl md:text-5xl font-extrabold mt-3 mb-4">Portfolio</h1>
      <p class="text-gray-400 text-lg">Et utvalg av prosjekter vi har levert.</p>
    </div>
  </section>

  <section class="pb-24 px-6">
    <div class="max-w-5xl mx-auto">

      <!-- Løft App - featured project -->
      <div class="bg-gray-900 border border-gray-800 rounded-2xl overflow-hidden mb-8">
        <div class="p-8 md:p-10">
          <span class="text-xs text-orange-400 font-semibold uppercase tracking-wider">Mobilapp</span>
          <h2 class="text-2xl font-bold mt-1 mb-3">Løft – Treningsapp</h2>
          <p class="text-gray-400 mb-6 max-w-2xl">
            En fullverdig treningsapp for iOS og Android. Brukerne kan logge økter, følge strukturerte programmer,
            spore fremgang og planlegge treningen sin med en innebygd kalender. Designet med fokus på enkel og rask bruk under trening.
          </p>
          <div class="flex flex-wrap gap-2 mb-8">
            {['React Native', 'iOS', 'Android', 'Supabase', 'TypeScript'].map(tag => (
              <span class="text-xs bg-gray-800 text-gray-400 px-2 py-1 rounded-md">{tag}</span>
            ))}
          </div>
          <!-- App screenshots -->
          <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
            <div class="rounded-2xl overflow-hidden border border-gray-700">
              <img src="/images/loft-hjem.jpg" alt="Løft app - Hjem" class="w-full h-auto object-cover" />
            </div>
            <div class="rounded-2xl overflow-hidden border border-gray-700">
              <img src="/images/loft-okt.jpg" alt="Løft app - Økt" class="w-full h-auto object-cover" />
            </div>
            <div class="rounded-2xl overflow-hidden border border-gray-700">
              <img src="/images/loft-programmer.jpg" alt="Løft app - Programmer" class="w-full h-auto object-cover" />
            </div>
            <div class="rounded-2xl overflow-hidden border border-gray-700">
              <img src="/images/loft-kalender.jpg" alt="Løft app - Kalender" class="w-full h-auto object-cover" />
            </div>
          </div>
        </div>
      </div>

    </div>

    <div class="max-w-5xl mx-auto mt-6 text-center">
      <p class="text-gray-500 text-sm">Vil du se mer? Ta kontakt – vi viser deg gjerne mer av arbeidet vårt.</p>
      <a href="/kontakt" class="inline-block mt-4 text-cyan-400 hover:text-cyan-300 font-semibold transition-colors">
        Send en melding →
      </a>
    </div>
  </section>

</Layout>
