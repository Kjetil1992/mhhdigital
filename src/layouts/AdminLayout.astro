---
import '../styles/global.css';

interface Props {
  title: string;
}
const { title } = Astro.props;
const path = Astro.url.pathname;

const nav = [
  { href: '/admin/dashboard', label: 'Oversikt', icon: '📊' },
  { href: '/admin/fakturaer', label: 'Fakturaer', icon: '🧾' },
  { href: '/admin/kunder', label: 'Kunder', icon: '👤' },
  { href: '/admin/prosjekter', label: 'Prosjekter', icon: '📁' },
];
---

<!doctype html>
<html lang="no">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} – Admin</title>
</head>
<body class="bg-gray-950 text-gray-100 min-h-screen flex">

  <!-- Sidebar -->
  <aside class="w-56 bg-gray-900 border-r border-gray-800 flex flex-col min-h-screen fixed top-0 left-0">
    <div class="p-5 border-b border-gray-800">
      <span class="font-bold text-white">MHH</span><span class="font-bold text-cyan-400">Digital</span>
      <p class="text-xs text-gray-500 mt-0.5">Admin</p>
    </div>
    <nav class="flex-1 p-3 space-y-1">
      {nav.map(n => (
        <a
          href={n.href}
          class={`flex items-center gap-3 px-3 py-2 rounded-lg text-sm font-medium transition-colors ${path.startsWith(n.href) ? 'bg-cyan-950 text-cyan-400' : 'text-gray-400 hover:text-white hover:bg-gray-800'}`}
        >
          <span>{n.icon}</span>
          {n.label}
        </a>
      ))}
    </nav>
    <div class="p-3 border-t border-gray-800">
      <form method="POST" action="/api/auth/logout">
        <button class="w-full text-left px-3 py-2 text-sm text-gray-500 hover:text-white transition-colors rounded-lg hover:bg-gray-800">
          🚪 Logg ut
        </button>
      </form>
    </div>
  </aside>

  <!-- Main -->
  <main class="ml-56 flex-1 p-8">
    <slot />
  </main>

</body>
</html>
